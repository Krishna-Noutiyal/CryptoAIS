    <ROW Section="Update v2.0.0" Key="ReleaseDate" Value="23755" ValueLocId="-"/>
    <ROW Section="Update v2.0.0" Key="SHA256" Value="release\CryptoAIS v2.0.0.exe" ValueLocId="-"/>
